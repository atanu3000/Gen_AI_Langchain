# Copy this file to a new file named .env and replace the value above with your real API key.

GOOGLE_API_KEY=your_gemini_api_key_here

HUGGINGFACEHUB_ACCESS_TOKEN=your_huggingface_access_token_here 
# You can get this token from https://huggingface.co/settings/tokens
# And make sure to give it the "read" role.
# Use `hf auth login` to log in to Hugging Face and get your token.